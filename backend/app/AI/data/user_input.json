    {
        "Title": "Transcribe Podcast Interviews",
        "Brief Description": "Create a word-for-word text transcript of podcast audio files.",
        "Category": "Annotation",
        "Subcategory": "Transcription",
        "Class Descriptions": {},
        "Background": "We are making our podcast episodes accessible and searchable by providing text transcripts.",
        "Objectives": [
            "Transcribe 10 hours of audio.",
            "Achieve >98% accuracy.",
            "Identify different speakers."
        ],
        "Step-by-Step Instructions": [
            {
                "stepNumber": "1",
                "instruction": "Listen to the audio and type what is said."
            },
            {
                "stepNumber": "2",
                "instruction": "Do not correct grammar, transcribe verbatim (e.g., include 'um', 'uh')."
            },
            {
                "stepNumber": "3",
                "instruction": "Prefix each new speaker's dialogue with '[SPEAKER 1]', '[SPEAKER 2]', etc."
            },
            {
                "stepNumber": "4",
                "instruction": "Use '[MUSIC]' or '[LAUGHTER]' for non-speech sounds."
            }
        ],
        "Technical Requirements": {
            "Tool": "Any text editor",
            "Format": "Plain text (.txt) file",
            "Other": []
        },
        "Evaluation Criteria": {
            "Quality Standards": [
                "Transcript must be accurate.",
                "All speakers must be identified."
            ],
            "Review Checklist": [
                "Does the text match the audio?",
                "Are speakers labeled?"
            ]
        }
    },
