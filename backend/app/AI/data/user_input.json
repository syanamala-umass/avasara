    {
        "Title": "Tumor Segmentation in MRI Scans",
        "Brief Description": "Delineate tumor boundaries in a dataset of brain MRIs.",
        "Category": "Annotation",
        "Subcategory": "Image Segmentation",
        "Class Descriptions": {
            "TUMOR": ["Glioblastoma multiforme regions"],
            "EDEMA": ["Peritumoral edematous tissue"]
        },
        "Background": "Data is for training a new deep learning model for automated oncological analysis.",
        "Objectives": [
            "Segment all specified tissues in 300 MRI slices.",
            "Ensure high fidelity to the ground truth."
        ],
        "Step-by-Step Instructions": [
            {
                "stepNumber": "1",
                "instruction": "Load each DICOM file."
            },
            {
                "stepNumber": "2",
                "instruction": "On the T2-FLAIR sequence, create a polygonal mask for the edema class. Similarly for ependymomas."
            },
            {
                "stepNumber": "3",
                "instruction": "On the T1-Gd sequence, create a mask for oligodendrogliomas and glioblastomas."
            },
            {
                "stepNumber": "4",
                "instruction": "Ensure Dice score would be > 0.9 on review."
            }
        ],
        "Technical Requirements": {
            "Tool": "ITK-SNAP or 3D Slicer",
            "Format": "NIfTI (.nii.gz)",
            "Other": []
        },
        "Evaluation Criteria": {
            "Quality Standards": [
                "Masks must be voxel-perfect.",
                "Correct class assignment per sequence."
            ],
            "Review Checklist": [
                "Is the edema mask correct?",
                "Is the tumor mask correct?"
            ]
        }
    },
